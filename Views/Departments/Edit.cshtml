@model EmployeeManagementWeb.Models.Department

@{
    Layout = "_Layout";
}

<div class="form-card">
    <h2>部門更新</h2>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="DepartmentId" />

        <div class="form-group">
            <label asp-for="DepartmentName"></label>
            <input asp-for="DepartmentName" class="form-control" />
            <span asp-validation-for="DepartmentName" class="validation"></span>
        </div>

        <div class="button-area">
            <button type="submit" class="btn btn-primary">更新</button>
            <a asp-action="Index" class="btn btn-secondary">戻る</a>
        </div>
    </form>
</div>