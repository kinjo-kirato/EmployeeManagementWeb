@model EmployeeManagementWeb.Models.Employee

@{
    Layout = "_Layout";
}

<div class="form-card">
    <h2>社員登録</h2>

    <form asp-action="Create" method="post">
        <div class="form-group">
            <label asp-for="EmployeeNumber"></label>
            <input asp-for="EmployeeNumber" class="form-control" />
            <span asp-validation-for="EmployeeNumber" class="validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="EmployeeName"></label>
            <input asp-for="EmployeeName" class="form-control" />
            <span asp-validation-for="EmployeeName" class="validation"></span>
        </div>


        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="HireDate"></label>
            <input asp-for="HireDate" type="date" class="form-control" />
            <span asp-validation-for="HireDate" class="validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="Position"></label>
            <input asp-for="Position" class="form-control" />
            <span asp-validation-for="Position" class="validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="DepartmentId"></label>
            <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-control">
                <option value="">部門を選択してください</option>
            </select>
            <span asp-validation-for="DepartmentId" class="validation"></span>
        </div>

        <div class="button-area">
            <button type="submit" class="btn btn-primary">登録</button>
            <a asp-action="Index" class="btn btn-secondary">戻る</a>
        </div>
    </form>
</div>