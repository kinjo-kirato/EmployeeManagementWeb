@model EmployeeManagementWeb.Models.LoginViewModel

@{
    Layout = "_Layout";
}

<div class="login-wrapper">
    <div class="login-card">
        <h2>ログイン</h2>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="error-message">
                @ViewBag.ErrorMessage
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="form-group">
                <label asp-for="UserId"></label>
                <input asp-for="UserId" class="form-control" autocomplete="off" />
                <span asp-validation-for="UserId" class="validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" type="password" class="form-control" autocomplete="off" />
                <span asp-validation-for="Password" class="validation"></span>
            </div>

            <button type="submit" class="btn btn-primary full-width">
                ログイン
            </button>
        </form>

    </div>
</div>